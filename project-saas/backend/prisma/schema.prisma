// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================
// 1. TENANT — L'établissement (la "société" qui paie le SaaS)
// =============================================================
// C'est la racine de tout. Chaque donnée de la base
// appartient à un Tenant grâce au champ tenantId.
// Si tu supprimes un Tenant, tout ce qui lui appartient
// est supprimé en cascade (onDelete: Cascade).

model Tenant {
  id           String       @id @default(uuid())  // Identifiant unique universel
  name         String                              // Ex : "Le Bistrot du Port"
  businessType BusinessType @default(RESTAURANT)   // Type d'établissement
  createdAt    DateTime     @default(now())

  // Relations — un Tenant possède tout ça :
  users         User[]
  staff         Staff[] 
  roles         Role[]
  categories    Category[]
  products      Product[]
  orders        Order[] 
  cycles        Cycle[]
  expenses      Expense[]
  payments      Payment[]
  notifications Notification[]
  tables Table[]
  reports Report[]
  statistics    Statistic[] // Statistiques générées pour cet établissement
  subscription  Subscription?  // Un seul abonnement par établissement
}

// Les types d'établissements supportés
enum BusinessType {
  RESTAURANT
  BAR
  CAFE
  FASTFOOD
}

// =============================================================
// 2. USER — Le propriétaire ou manager (accès web au dashboard)
// =============================================================
// Ce sont les comptes qui se connectent avec email/mot de passe
// pour gérer l'établissement depuis l'interface SaaS.

model User {
  id        String   @id @default(uuid())
  tenantId  String                          // Appartient à quel établissement
  email     String   @unique  // Email de connexion (unique global)
  phone     String?           // Numéro de téléphone
  password  String            // Mot de passe doit etre hashe
  role      UserRole @default(MANAGER)      // ADMIN = propriétaire, MANAGER = gérant
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum UserRole {
  SUPERADMIN // Administrateur du système SaaS
  ADMIN    // Propriétaire — accès total à l'établissement
  MANAGER  // Gérant — accès limité à l'établissement
}


// =============================================================
// 3. ROLE — Rôles dynamiques pour le staff (définis par tenant)
// =============================================================
// Chaque établissement crée ses propres rôles avec ses propres
// permissions. Ex : un bar n'a pas de "CHEF" mais un "BARMAN".
// Les permissions sont une liste de strings ex: ["CREATE_ORDER"]


model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String                   // Ex : "SERVEUR", "BARMAN", "CHEF"
  permissions String[]                 // Ex : ["VIEW_ORDERS", "UPDATE_ORDER_STATUS"]

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff  Staff[]                       // Les employés qui ont ce rôle
}

// =============================================================
// 4. STAFF — Les employés opérationnels (se connectent via PIN)
// =============================================================
// Les employés ne se connectent PAS avec email/mot de passe.
// Ils utilisent un code PIN (à 4 chiffres) sur une tablette
// en caisse ou en salle. Le PIN est stocké hashé (sécurité).

model Staff {
  id        String   @id @default(uuid())
  tenantId  String
  roleId    String                     // Quel rôle a cet employé
  name      String                     // Ex : "Jean-Marc"
  identifier String   @unique                // Identifiant unique global (ex: JM01, BISTROT_JEAN)
  pinHash    String                     // PIN hashé avec bcrypt
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id])
}

// =============================================================
// 5. CATEGORY — Catégories du menu
// =============================================================
// Organise les produits. Type FOOD ou DRINK permet d'adapter
// l'affichage selon le type d'établissement.
// Ex restaurant : Entrées, Plats, Desserts (FOOD)
// Ex bar : Cocktails, Bières, Softs (DRINK)

model Category {
  id       String       @id @default(uuid())
  tenantId String
  name     String                       // Ex : "Entrées"
  type     CategoryType @default(DRINK)                 // FOOD ou DRINK

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]                    // Les produits dans cette catégorie
}

enum CategoryType {
  FOOD
  DRINK
}


// =============================================================
// 6. PRODUCT — Les articles vendus (plats, boissons, etc.)
// =============================================================
// price    = prix de vente (affiché au client)
// costPrice = prix de revient (pour calculer la marge)
// stock / minStock = gestion des stocks avec alerte bas stock

model Product {
  id          String   @id @default(uuid())
  tenantId    String
  categoryId  String
  name        String                     // Ex : "Salade César"
  price       Float                      // Prix de vente : 12.50
  costPrice   Float    @default(0)       // Prix de revient : 4.20
  stock       Int      @default(0)       // Stock actuel : 50
  minStock    Int      @default(5)       // Alerte si stock < 5
  isActive    Boolean  @default(true)    // false = retiré du menu sans suppression
  unit        String?  @default("unité") // Ex : "plat", "bouteille", "kg"
  imageUrl    String?                    // Image du produit (upload local ou url)
  colorCode   String?                    // Code couleur Hex pour le template de la carte
  createdAt   DateTime @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
}


// Table report 
model Report {
  id        String   @id @default(uuid())
  tenantId  String
  cycleId   String @unique
  totalRevenu Float
  totalExpenses Float
  netProfit Float
  cashDifference Float
  paymentByMethod Json
  createdAt DateTime @default(now())


  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycle  Cycle  @relation(fields: [cycleId], references: [id]) // un rapport pour un cycle
}

// =============================================================
// 7. CYCLE — La journée / session de caisse
// =============================================================
// Avant de travailler, le caissier "ouvre la caisse" → crée un Cycle.
// Toutes les commandes et dépenses de la journée sont liées à ce Cycle.
// En fin de journée : fermeture → Cycle passe à CLOSED.
// Permet de faire des rapports journaliers précis.

model Cycle {
  id        String      @id @default(uuid())
  tenantId  String
  openedAt  DateTime    @default(now())   // Heure d'ouverture
  closedAt  DateTime?                     // Heure de fermeture (null si encore ouvert)
  status    CycleStatus @default(OPEN)

  openingCash  Float? @default(0)
  closingCash  Float? @default(0)

  note       String? @default("")
  
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders   Order[]                        // Toutes les commandes de cette session
  expenses Expense[]                      // Toutes les dépenses de cette session
  report   Report?                       // le rapport de la journée
}

enum CycleStatus {
  OPEN    // Caisse ouverte — on peut prendre des commandes
  CLOSED  // Caisse fermée — journée terminée
}


// ==========================================================
// (modifcation) Table - la table du client
// ==========================================================
// qrtoken = associer pour la reconnaissance de la table grace au qrcode 


model Table {
  id        String        @id @default(uuid())
  tenantId  String 
  qrToken   String   @unique @default(uuid())
  name      String 
  
  isActive  Boolean  @default(true)
  createAt  DateTime @default(now())
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders   Order[]

}

// =============================================================
// 8. ORDER — Une commande client
// =============================================================
// tableName = numéro ou nom de la table ("Table 5", "Bar", "Terrasse 2")
// status suit le cycle de vie de la commande :
//   PENDING  → commande passée, en attente
//   ACCEPTED → prise en charge par la cuisine/bar
//   READY    → prête à être servie
//   PAID     → réglée

model Order {
  id          String      @id @default(uuid())
  tenantId    String
  cycleId     String                         // Rattachée à la session du jour
  tableId   String?                        // Ex : "Table 3" (Optionnel pour vente emportée)
  status      OrderStatus @default(PENDING)
  totalAmount Float       @default(0)        // Total calculé automatiquement
  createdAt   DateTime    @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycle      Cycle       @relation(fields: [cycleId], references: [id])
  table      Table?      @relation(fields: [tableId], references: [id])
  items      OrderItem[]
  payments   Payment[] 
}



enum OrderStatus {
  PENDING   // En attente (Client)
  ACCEPTED  // Prise en charge
  READY     // Prête
  VALIDATED // Validée (Staff)
  REJECTED  // Rejetée
  PAID      // Payée
}

// =============================================================
// 9. ORDER ITEM — Le détail d'une commande (ligne par ligne)
// =============================================================
// Une commande peut avoir plusieurs items.
// Ex : 2x Salade César + 1x Eau minérale
// Le price ici est une copie du prix au moment de la commande
// (si tu changes le prix du produit après, l'historique reste correct)

model OrderItem {
  id        String @id @default(uuid())
  tenantId  String
  orderId   String
  productId String
  quantity  Int                             // Quantité : 2
  price     Float                           // Prix unitaire au moment de l'achat : 12.50

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// =============================================================
// 10. EXPENSE — Les dépenses de l'établissement
// =============================================================
// Tout ce que l'établissement dépense (achat fournisseur,
// réparation, fournitures...) est enregistré ici et rattaché
// au cycle du jour pour les rapports journaliers.

model Expense {
  id          String   @id @default(uuid())
  tenantId    String
  cycleId     String
  amount      Float                        // Montant dépensé
  description String                       // Ex : "Achat légumes marché"
  imageUrl    String?                      // Photo du reçu / justificatif
  createdAt   DateTime @default(now())
  category    ExpenseCategory             // Catégorie de la dépense

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycle  Cycle  @relation(fields: [cycleId], references: [id])
}

//enum pour les categories de depense

enum ExpenseCategory {
    SUPPLIES
    MAINTENANCE
    RENT
    SALARY
    UTILITIES
    MARKETING
    EQUIPEMENT
    OTHER
}


// =============================================================
// 11. PAYMENT — L'enregistrement du paiement d'une commande
// =============================================================
// Une commande peut avoir plusieurs paiements
// (paiement fractionné, ex : moitié cash + moitié mobile money)
// Méthodes adaptées au contexte Afrique de l'Ouest :
//   CASH, CARD (TPE), MOBILE_MONEY (Orange Money, Wave, MTN...)

model Payment {
  id        String        @id @default(uuid())
  tenantId  String
  orderId   String
  method    PaymentMethod
  amount    Float
  createdAt DateTime      @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id])
}

enum PaymentMethod {
  CASH          // Espèces
  CARD          // Carte bancaire
  MOBILE_MONEY  // Orange Money, Wave, MTN, etc.
}

// =============================================================
// 12. SUBSCRIPTION — L'abonnement SaaS de l'établissement
// =============================================================
// C'est le cœur du business SaaS.
// FREE = accès limité (ex : 50 commandes/mois)
// PRO = accès étendu
// BUSINESS = accès complet + multi-utilisateurs
// Si status = SUSPENDED → l'établissement perd l'accès

model Subscription {
  id        String             @id @default(uuid())
  tenantId  String             @unique               // Un seul abo par établissement
  plan          SubscriptionPlan   @default(FREE)
  pendingPlan   SubscriptionPlan?                    // Nouveau plan en attente de validation
  status        SubscriptionStatus @default(ACTIVE)
  startedAt DateTime           @default(now())
  expiresAt DateTime                                 // Date d'expiration

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum SubscriptionPlan {
  FREE      // Gratuit — fonctionnalités limitées
  PRO       // Intermédiaire
  BUSINESS  // Complet
}

enum SubscriptionStatus {
  ACTIVE     // Actif — accès normal
  PENDING    // En attente de validation par le Super Admin
  SUSPENDED  // Suspendu — paiement en retard
  EXPIRED    // Expiré
}

// =============================================================
// 13. NOTIFICATION — Alertes système pour l'établissement
// =============================================================
// Exemples de notifications automatiques :
// - "Stock de Coca-Cola faible (2 restants)"
// - "Nouvelle commande Table 5"
// - "Abonnement expire dans 3 jours"

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  title     String                         // Ex : "Stock faible"
  message   String                         // Ex : "Coca-Cola : 2 unités restantes"
  category  String   @default("INFO")      // INFO, WARNING, SYSTEM, SUCCESS
  isRead    Boolean  @default(false)       // Lue ou non
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// =============================================================
// 14. STATISTIC — Statistiques générées sur une période
// =============================================================
// Permet de sauvegarder des calculs statistiques générés sur une
// période spécifique. La période est limitée selon l'abonnement du tenant :
// FREE (max 2 jours), PRO (max 15 jours), BUSINESS (max 30 jours).
// Ce modèle stocke les agrégations (revenus, bénéfices) et les produits les plus vendus
// (topProducts en format JSON, incluant l'URL de l'image, nom, et quantité) pour
// être affichés sur le frontend avec le bouton "Plus de détails".

model Statistic {
  id             String   @id @default(uuid()) // Identifiant unique de la statistique
  tenantId       String                        // L'établissement auquel appartient cette statistique
  startDate      DateTime                      // Date de début du calcul statistique
  endDate        DateTime                      // Date de fin du calcul statistique
  totalRevenue   Float                         // Revenu total généré (Total des ventes)
  netProfit      Float                         // Bénéfice net généré (Revenus - Dépenses ou Coût de revient)
  topProducts    Json                          // Liste des produits les plus vendus (stockée en JSON pour flexibilité, ex: [{ productId, name, imageUrl, quantitySold }])
  createdAt      DateTime @default(now())      // Date et heure de la création de cet enregistrement

  // Relation avec le modèle Tenant
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// =============================================================
// 15. PRODUCT MODELS — Modèles de produits (Système)
// =============================================================
model ProductModelCategory {
  id       String         @id @default(uuid())
  name     String         @unique
  icon     String?        // Nom de l'icône React (ex: "FiCoffee")
  imageUrl String?        // Image de la catégorie
  models   ProductModel[]
}

model ProductModel {
  id          String   @id @default(uuid())
  categoryId  String
  name        String
  imageUrl    String?
  unit        String   @default("unité")
  
  category ProductModelCategory @relation(fields: [categoryId], references: [id])
}
